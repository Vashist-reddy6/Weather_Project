# ─────────────────────────────────────────────────────────────────────────────
# WeatherGuard AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is already excluded by .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────

# OpenWeatherMap API key — free at https://openweathermap.org/api
# Used for: real-time weather, 5-day forecast, geocoding
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Twilio — free trial at https://www.twilio.com/try-twilio
# Used for: SMS disaster alerts + inbound SMS bot
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Optional (improves accuracy) ─────────────────────────────────────────────

# Tomorrow.io — free at https://app.tomorrow.io/signup (500 calls/day)
# Used for: hyperlocal precipitation intensity + wind gust data
# Leave blank to fall back to OpenWeatherMap only.
TOMORROW_IO_API_KEY=your_tomorrow_io_api_key_here

# OpenAI — https://platform.openai.com (pay-per-use)
# Used for: GPT-powered chatbot responses + LLM risk narrative in predictions
# Leave blank to use the built-in rule-based engine (works fully offline).
OPENAI_API_KEY=sk-your_openai_key_here
