# ── ML artefacts ─────────────────────────────────────────────────────────────
ml/*.pkl
ml/*.joblib
ml/checkpoints/

# ── IDE / OS ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.DS_Store
Thumbs.db
desktop.ini

# ── Logs ───────────────────────────────────────────────────────────────────────
*.log
logs/
