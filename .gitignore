# ── Environment variables (NEVER commit secrets) ─────────────────────────────
.env
.env.local
.env.*.local

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
*.sqlite3
*.db
*.db-shm
*.db-wal

# ── Dataset files (large, use Git LFS or share separately) ────────────────────
*.xlsx
*.xls
*.csv

