# ─────────────────────────────────────────────────────────────────────────────
# WeatherGuard AI — Frontend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is already excluded by .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Optional ─────────────────────────────────────────────────────────────────

# Backend API URL — only needed when deploying frontend separately (e.g. Vercel)
# In local dev the Vite proxy in vite.config.js forwards /api → localhost:8000.
# In production set this to your deployed backend URL, e.g:
#   VITE_API_URL=https://weatherguard-backend.onrender.com
VITE_API_URL=
